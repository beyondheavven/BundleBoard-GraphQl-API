type MediaResource {
    id: ID!
    fileName: String!
    filePath: String!
    mimeType: MimeType!
    provider: Provider!
    fileSize: Int!
}

type GetMediaResourceByIdResponse {
    id: ID!
    fileName: String!
    fileSize: Int!
    mimeType: MimeType!
    provider: Provider!
}

enum Provider {
    local
    google_drive
}