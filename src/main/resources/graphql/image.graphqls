scalar Upload

extend type Mutation {
    uploadImage(file: Upload!): Image!
}

type Image {
    id: ID!
    fileName: String!
    mimeType: MimeType!
    filePath: String!
    width: Int!
    height: Int!
    filesize: Int!
}

type ImageResponse {
    id: ID!
    fileName: String!
    filePath: String!
    mimeType: String!
    width: Int
    height: Int
}

enum MimeType {
    jpeg
    png
    mp4
    zip
    rar
    pdf
}