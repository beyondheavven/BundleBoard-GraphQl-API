scalar Upload

extend type Mutation {
    uploadImage(file: Upload!): Image!
}

type Image {
    id: ID!
    fileName: String!
    mimeType: MimeType!
    filePath: String!
    width: Int!
    height: Int!
    filesize: Int!
}

type ImageShortResponse {
    filePath: String!
    fileName: String!
}

input ImageShortInput {
    filePath: String!
    fileName: String!
}

enum MimeType {
    jpeg
    png
    webp
    mp4
    zip
    rar
    pdf
}