type Query {
    getUserById(id:ID!): User
    getAllUsers: [User!]!
}

type User{
    id: ID!
    username: String!
    email: String!
    role: UserRole!
    avatarUrl: String
    status: UserStatus!
}

enum UserRole {
    admin, author, client
}

enum UserStatus {
    active, inactive, banned
}


